{
    "name": "deploycar/laravel-sync-manager",
    "description": "A Laravel package for incremental local-to-production sync with tracked state, history, and rollback support.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "DeployCar\\LaravelSyncManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeployCar\\LaravelSyncManager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DeployCar\\LaravelSyncManager\\SyncManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
